// prisma/schema.prisma
// 1. Configure the database connection
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 2. Define the core data models

// Core Categories for the services (e.g., Tutoring, Medical Advice)
model Category {
  id          String   @id @default(uuid())
  name        String   @unique // The unique name of the service
  description String?  // Optional description
  experts     Expert[] // Relationship to Experts in this category
}

// Client Users (seeking consulting)
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  timezone  String?  // Helpful for calendar scheduling later
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Add other client-specific fields if needed (e.g., bookedSessions)
}

// Professional Experts (providing consulting)
model Expert {
  id               String   @id @default(uuid())
  photoUrl         String?  // Optional image placeholder
  name             String
  email            String   @unique // For accept/reject notifications
  password         String
  yearsExperience Int
  pricePerHour     Decimal  // Calculated and displayed later
  subjectExpertise String[] // Array of specific expertise (e.g., ['Calculus', 'Physics'])
  isAvailable      Boolean  @default(true) // For presence status
  bio              String?
  marketingSnippet String?
  
  // Relationships
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
}

// Payment Transactions
model Transaction {
  id            String   @id @default(uuid())
  orderId       String   @unique
  paymentId     String?  @unique
  signature     String?
  amount        Int      // in subunit (paise/cents)
  currency      String   @default("INR")
  status        String   @default("CREATED") // CREATED, PAID, FAILED
  userId        String?
  expertId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}