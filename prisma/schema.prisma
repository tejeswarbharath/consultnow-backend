// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Professional Experts (providing consulting)
model Expert {
  id               String   @id @default(uuid())
  photoUrl         String?
  name             String
  email            String   @unique 
  password         String
  yearsExperience  Int
  pricePerHour     Float
  currency         String   @default("INR") // NEW: Currency Flexibility
  
  subjectExpertise String 
  isAvailable      Boolean  @default(true) 
  bio              String?
  marketingSnippet String?
}

// Payment Transactions
model Transaction {
  id            String   @id @default(uuid())
  orderId       String   @unique
  paymentId     String?  @unique
  signature     String?
  amount        Int      // in subunit (paise/cents)
  currency      String   @default("INR") // Already supports dynamic currency
  status        String   @default("CREATED") // CREATED, PAID, FAILED
  expertId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}